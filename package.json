{
  "name": "@mra1k3r0/gramora",
  "version": "0.0.12",
  "description": "Telegram bot framework for TypeScript: a small API for everyday bots, stronger types when you need them, and practical runtime controls.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/examples/**",
    "!dist/src/**",
    "README.md"
  ],
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:examples": "tsc -p tsconfig.examples.json",
    "dev": "tsc -w -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run check && npm run lint && npm run format:check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "npm run build && node scripts/bench.mjs",
    "size": "npm run build && node scripts/size-report.mjs",
    "example:functional": "npm run build:examples && node dist/examples/functional-test-bot.js",
    "example:rich-text": "npm run build:examples && node dist/examples/rich-text-bot.js",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "telegram",
    "telegram-bot",
    "telegram-api",
    "bot-framework",
    "gramora",
    "nodejs",
    "typescript",
    "middleware",
    "webhook"
  ],
  "author": "mra1k3r0",
  "homepage": "https://github.com/mra1k3r0/gramora",
  "bugs": {
    "url": "https://github.com/mra1k3r0/gramora/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mra1k3r0/gramora"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "undici": "^8.0.2"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^3.2.4",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "semantic-release": "^24.2.3",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
